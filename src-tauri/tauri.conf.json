{
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "frontendDist": "../ui"
  },
  "bundle": {
    "resources": [
      "resources/**/*"
    ],
    "active": true,
    "createUpdaterArtifacts": true,
    "category": "DeveloperTool",
    "copyright": "",
    "targets": "all",
    "externalBin": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "longDescription": "A simple file explorer with nice ui and good features.",
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null
    },
    "shortDescription": "",
    "linux": {
      "deb": {
        "depends": []
      }
    }
  },
  "productName": "CoDriver",
  "mainBinaryName": "CoDriver",
  "version": "0.7.6",
  "identifier": "com.codriver.dev",
  "plugins": {
    "cli": {
      "args": [
        {
          "name": "source",
          "short": "s",
          "index": 1,
          "takesValue": true
        }
      ]
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZGRTc2QTcyRjBFQzJBRTMKUldUakt1endjbXJuLzcwSExENGpId0M3MlJTZmVDeTUzdmFaZFNZanhnVEY1Rm5Zc2k5cXJRbHYK",
      "endpoints": [
        "https://github.com/RickyDane/CoDriver/releases/latest/download/latest.json"
      ]
    }
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "security": {
      "assetProtocol": {
        "scope": {
          "allow": [
            "**/*"
          ],
          "deny": [],
          "requireLiteralLeadingDot": false
        },
        "enable": true
      },
      "csp": null
    },
    "windows": [
      {
        "decorations": true,
        "fullscreen": false,
        "transparent": true,
        "height": 700,
        "resizable": true,
        "title": "CoDriver",
        "width": 1100,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 25,
          "y": 25
        },
        "useHttpsScheme": true
      }
    ]
  }
}
