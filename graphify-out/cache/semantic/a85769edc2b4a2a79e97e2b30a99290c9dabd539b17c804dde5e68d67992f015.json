{"nodes": [{"id": "disk_sidebar_fixes_decisions_decisions", "label": "Disk Sidebar Display and Usage Refresh Fixes Decisions", "file_type": "document", "source_file": "docs/planning/disk-sidebar-fixes/decisions.md", "source_location": null, "source_url": null, "captured_at": null, "author": "software-engineer", "contributor": null}, {"id": "disk_sidebar_fixes_decisions_display_only_quote_cleanup", "label": "Display-Only Quote Cleanup Rationale", "file_type": "rationale", "source_file": "docs/planning/disk-sidebar-fixes/decisions.md", "source_location": null, "source_url": null, "captured_at": null, "author": "software-engineer", "contributor": null, "rationale": "Stripping outer quote pairs must be purely presentation-level. Mutating raw disk paths or names risks breaking directory navigation, unmounting, and backend filesystem API calls."}, {"id": "disk_sidebar_fixes_decisions_event_driven_disk_refresh", "label": "Event-Driven Disk Refresh Rationale", "file_type": "rationale", "source_file": "docs/planning/disk-sidebar-fixes/decisions.md", "source_location": null, "source_url": null, "captured_at": null, "author": "software-engineer", "contributor": null, "rationale": "Coalescing disk usage refreshes after file operation completions via debouncing avoids constant background polling, preserving CPU cycles and UI responsiveness."}], "edges": [{"source": "disk_sidebar_fixes_decisions_decisions", "target": "disk_sidebar_fixes_plan_sidebar_fixes_plan", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/planning/disk-sidebar-fixes/decisions.md", "source_location": null, "weight": 1.0}, {"source": "disk_sidebar_fixes_decisions_display_only_quote_cleanup", "target": "ui_main_logic_displaydiskname", "relation": "rationale_for", "confidence": "INFERRED", "confidence_score": 0.95, "source_file": "docs/planning/disk-sidebar-fixes/decisions.md", "source_location": null, "weight": 1.0}, {"source": "disk_sidebar_fixes_decisions_e